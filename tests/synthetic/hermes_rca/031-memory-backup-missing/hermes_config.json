{
  "provider": "openai",
  "model": "gpt-5.4-mini",
  "region": "us-east-1",

  "providers": [
    {
      "name": "openai",
      "base_url": "https://api.openai.com",
      "auth_kind": "api_key"
    }
  ],

  "transport": {
    "sse_max_line_bytes": 131072,
    "request_timeout_s": 120
  },

  "memory": {
    "enabled": true,
    "backend": "local_filesystem",
    "fallback_allowed": false
  }
}
