{
  "provider": "openai",
  "model": "gpt-5.4-mini",
  "region": "us-east-1",
  "providers": [
    {
      "name": "openai",
      "base_url": "https://api.openai.com",
      "auth_kind": "api_key"
    }
  ],
  "transport": {
    "sse_max_line_bytes": 131072,
    "request_timeout_s": 120
  },
  "peer_agent": {
    "protocol": "a2a",
    "endpoint": "http://peer-agent.internal:8080"
  }
}
