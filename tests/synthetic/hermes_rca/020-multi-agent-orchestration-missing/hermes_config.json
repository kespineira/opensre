{
  "provider": "openai",
  "model": "gpt-5.4-mini",
  "region": "us-east-1",
  "providers": [
    {
      "name": "openai",
      "base_url": "https://api.openai.com",
      "auth_kind": "api_key"
    }
  ],
  "transport": {
    "sse_max_line_bytes": 131072,
    "request_timeout_s": 120
  },
  "orchestration": {
    "enabled": true,
    "topology": "planner_worker_reviewer",
    "roles": [
      {
        "name": "planner",
        "model": "gpt-5.4-mini"
      },
      {
        "name": "worker",
        "model": "gpt-5.4-mini"
      },
      {
        "name": "reviewer",
        "model": "gpt-5.4-mini"
      }
    ]
  }
}
