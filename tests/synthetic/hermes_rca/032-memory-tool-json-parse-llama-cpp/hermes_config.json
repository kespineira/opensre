{
  "provider": "llama.cpp",
  "model": "llama-3-70b",
  "region": "local",

  "providers": [
    {
      "name": "llama.cpp",
      "base_url": "http://localhost:8080",
      "auth_kind": "none"
    }
  ],

  "transport": {
    "sse_max_line_bytes": 131072,
    "request_timeout_s": 120
  },

  "memory": {
    "enabled": true,
    "backend": "in_process",
    "fallback_allowed": false
  }
}
